# ---- Servidor ----
NODE_ENV=development
SERVER_PORT=8080

# ---- Banco (PostgreSQL) ----
DATABASE_URL=postgresql://digimon:digimon@localhost:5432/digimon

# ---- Redis ----
REDIS_URL=redis://localhost:6379

# ---- Auth ----
JWT_SECRET=troque-este-segredo-em-producao
JWT_EXPIRES_IN=7d

# ---- Cliente web ----
VITE_WS_URL=ws://localhost:8080

# ---- Importador de cartas ----
# Fonte pública dos dados das cartas (somente dados, sem artes)
CARD_API_BASE=https://digimoncard.io/api-public
